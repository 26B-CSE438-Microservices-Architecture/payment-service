generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Payment {
  id             String   @id @db.VarChar(20)
  idempotencyKey String   @unique @map("idempotency_key") @db.VarChar(100)
  orderId        String   @map("order_id") @db.VarChar(50)
  userId         String   @map("user_id") @db.VarChar(50)
  amount         Int
  currency       String   @default("TRY") @db.VarChar(3)
  method         String   @default("card") @db.VarChar(20)
  status         String   @db.VarChar(20)
  provider       String?  @db.VarChar(20)
  providerTxId   String?  @map("provider_tx_id") @db.VarChar(100)
  failureReason  String?  @map("failure_reason")
  metadata       Json?
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz()
  authorizedAt   DateTime? @map("authorized_at") @db.Timestamptz()
  capturedAt     DateTime? @map("captured_at") @db.Timestamptz()
  cancelledAt    DateTime? @map("cancelled_at") @db.Timestamptz()
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  events PaymentEvent[]

  @@index([orderId], map: "idx_payments_order_id")
  @@index([status], map: "idx_payments_status")
  @@map("payments")
}

model PaymentEvent {
  id          Int      @id @default(autoincrement())
  paymentId   String   @map("payment_id") @db.VarChar(20)
  fromStatus  String?  @map("from_status") @db.VarChar(20)
  toStatus    String   @map("to_status") @db.VarChar(20)
  triggeredBy String?  @map("triggered_by") @db.VarChar(50)
  details     Json?
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz()

  payment Payment @relation(fields: [paymentId], references: [id])

  @@index([paymentId], map: "idx_payment_events_payment_id")
  @@map("payment_events")
}

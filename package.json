  "dependencies": {
    "@prisma/client": "^6.19.2",
    "amqplib": "^0.10.9",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "iyzipay": "^2.0.65",
    "jsonwebtoken": "^9.0.3",
    "uuid": "^13.0.0"
  },

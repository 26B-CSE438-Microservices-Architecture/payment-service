{
  "name": "microservices-payment",
  "version": "1.0.0",
  "description": "Handles payment lifecycle operations for the Trendyol clone platform. This service processes card payments via a third-party provider and publishes payment state changes as events for other services to consume.",
  "main": "index.js",
  "scripts": {
    "start": "node src/index.js",
    "worker": "node src/worker/index.js",
    "migrate": "npx prisma migrate dev",

    "generate": "npx prisma generate",
    "studio": "npx prisma studio",
    "test": "jest --verbose",
    "test:coverage": "jest --coverage --verbose"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/26B-CSE438-Microservices-Architecture/payment-service.git"
  },
